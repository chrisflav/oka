-/

open CategoryTheory TopologicalSpace Opposite Limits SheafOfModules AlgebraicGeometry

universe u

namespace ComplexAnalytic

/-- If the restriction of `X` to an open set `U` is a local model, then `đȘ_X` has locally
finitely generated relations over `U`.

This is the geometric heart of the deduction, and the point at which Oka's coherence theorem
for `â^n` is used. Writing the local model as a closed immersion `i : X|_U â¶ Y` into an open
subset `Y` of `â^n` cutting out `X|_U` by `fâ, âŠ, f_k`:

1. near a point, finitely many sections `sâ, âŠ, s_m` of `đȘ_X` lift along the surjection
   `đȘ_Y â  i_*đȘ_{X|_U}` to sections `tâ, âŠ, t_m` of `đȘ_Y`;
2. `đȘ_Y` has locally finitely generated relations, by `hasLocalRelations_complexSpace`
   restricted to `Y`, so the relations between `tâ, âŠ, t_m, fâ, âŠ, f_k` are generated by
   finitely many of them;
3. discarding the last `k` coordinates of those generators gives generators for the relations
   between the `sá”ą`, since a relation `â aá”ą sá”ą = 0` lifts to `â aá”ą tá”ą â (fâ, âŠ, f_k)`. -/
theorem IsLocalModel.hasLocalRelationsOn {X : LocallyRingedSpace.{u}} (U : Opens X)
    (h : IsLocalModel (X.restrict U.isOpenEmbedding)) :
    X.HasLocalRelationsOn U :=
  sorry

/-- **Coherence of the structure sheaf of a complex analytic space.**

Every point of an analytic space has a neighbourhood isomorphic to a local model, whose
structure sheaf has locally finitely generated relations; since that condition is local it
holds on all of `X`, and hence `đȘ_X` is coherent. -/
theorem AnalyticSpace.isCoherentStructureSheaf (X : AnalyticSpace.{u}) :
    X.toLocallyRingedSpace.IsCoherentStructureSheaf := by
  choose U M hM he using X.local_model
  refine LocallyRingedSpace.isCoherentStructureSheaf_of_hasLocalRelations _
    (LocallyRingedSpace.hasLocalRelations_of_openCover
      (fun x : X.toLocallyRingedSpace âŠ (U x).1) (fun x âŠ âšx, (U x).2â©) fun x âŠ ?_)
  exact IsLocalModel.hasLocalRelationsOn _ (IsLocalModel.of_iso (he x).some (hM x))

end ComplexAnalytic
