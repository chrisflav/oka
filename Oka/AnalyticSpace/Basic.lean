import Mathlib.Geometry.RingedSpace.OpenImmersion
import Oka.ComplexSpace

/-!
# Complex analytic spaces

We define complex analytic spaces following the definition of `AlgebraicGeometry.Scheme` in
mathlib: an analytic space is a locally ringed space, equipped with a `ℂ`-algebra structure
on its structure sheaf, every point of which has an open neighbourhood which is — compatibly
with the `ℂ`-algebra structures — a *local model*.

A local model is the common zero locus `A` of finitely many holomorphic functions
`f₁, …, f_k` on an open subset `U ⊆ ℂ^n`, equipped with the structure sheaf
`(𝒪_U / (f₁, …, f_k))|_A`. Rather than constructing this quotient sheaf, we characterise the
result by the closed immersion `i : A ⟶ U` it comes with, in the style of
`AlgebraicGeometry.IsClosedImmersion`: the underlying map of `i` is a closed embedding onto
the zero locus of the `fⱼ`, the maps on stalks are surjective, and their kernels are the
ideals generated by the germs of the `fⱼ`. This determines `(A, 𝒪_A)` up to isomorphism and
is what the classical definition amounts to.

The `ℂ`-algebra structure is recorded as a ring homomorphism `ℂ →+* Γ(X, 𝒪_X)` into the
global sections; the ring of sections over every open subset then becomes a `ℂ`-algebra via
restriction. It cannot be omitted: a ring isomorphism between sheaves of holomorphic
functions may be conjugate-linear (complex conjugation is a ring automorphism of `ℂ`), so
locally ringed spaces which are merely locally isomorphic to local models also include
spaces glued along antiholomorphic transition maps — dianalytic spaces such as Klein
surfaces — and plain morphisms of locally ringed spaces include antiholomorphic maps such
as complex conjugation itself. Requiring charts (`AnalyticSpace.local_model`) and morphisms
(`AnalyticSpace.Hom`) to pull constant functions back to constants is precisely the
classical condition that a complex space is a `ℂ`-ringed space and that its morphisms are
morphisms of `ℂ`-ringed spaces.

As for `AlgebraicGeometry.Scheme`, no separation axiom is imposed; the Hausdorffness
assumed by most classical treatments should be added as a mixin where needed.

## Main definitions

- `ComplexAnalytic.IsCutOutBy i f`: the closed immersion `i : X ⟶ Y` exhibits `X` as the
  analytic subspace of `Y` cut out by the global sections `f`.
- `ComplexAnalytic.IsLocalModel X`: `X` is a local model, i.e. an analytic subspace of an open
  subset of some `ℂ^n`, as a locally ringed space.
- `AlgebraicGeometry.LocallyRingedSpace.resAlgMap`: the `ℂ`-algebra structure induced on an
  open subspace.
- `ComplexAnalytic.constantsAlgMap`: the constant functions as the canonical `ℂ`-algebra
  structure on an open subspace of `ℂ^n`.
- `ComplexAnalytic.IsCLinearHom i α β`: a morphism of locally ringed spaces is `ℂ`-linear
  with respect to `ℂ`-algebra structures on its source and target.
- `ComplexAnalytic.AnalyticSpace`: a complex analytic space.
- `ComplexAnalytic.AnalyticSpace.complexAffineSpace`: `ℂ^n` as a complex analytic space.

## References

- [Hans Grauert and Reinhold Remmert, *Coherent analytic sheaves*][grauert-remmert1984]
- [Hans Grauert and Reinhold Remmert, *Theory of Stein spaces*][grauert-remmert1979]
-/

open CategoryTheory TopologicalSpace Opposite AlgebraicGeometry Topology

universe u

namespace ComplexAnalytic

variable {X Y : LocallyRingedSpace.{u}}

/-- A closed immersion `i : X ⟶ Y` of locally ringed spaces *cuts out* `X` by the global
sections `f₁, …, f_k` of `𝒪_Y` if `X` is the common zero locus of the `fⱼ` and `𝒪_X` is the
quotient of `𝒪_Y` by the ideal they generate.

This is the intrinsic characterisation of the locally ringed space `(V(f), (𝒪_Y/(f))|_{V(f)})`:
any two closed immersions cutting out the same sections are canonically isomorphic. -/
structure IsCutOutBy (i : X ⟶ Y) {k : ℕ} (f : Fin k → Y.presheaf.obj (op ⊤)) : Prop where
  /-- `i` is a closed embedding of topological spaces. -/
  isClosedEmbedding : IsClosedEmbedding i.base
  /-- The image of `i` is the common zero locus of the `fⱼ`, i.e. the set of points at which
  every germ of every `fⱼ` is not a unit. -/
  range_base : Set.range i.base =
    {y | ∀ j, Y.presheaf.Γgerm y (f j) ∈ IsLocalRing.maximalIdeal (Y.presheaf.stalk y)}
  /-- The structure sheaf of `X` is a quotient of the structure sheaf of `Y`. -/
  surjective_stalkMap : ∀ x, Function.Surjective (i.stalkMap x).hom
  /-- The kernel of `𝒪_Y → 𝒪_X` is the ideal generated by the germs of the `fⱼ`. -/
  ker_stalkMap : ∀ x, RingHom.ker (i.stalkMap x).hom =
    Ideal.span (Set.range fun j ↦ Y.presheaf.Γgerm (i.base x) (f j))

/-- A locally ringed space is a **local model** for complex analytic geometry if it is the
common zero locus of finitely many holomorphic functions on an open subset of some `ℂ^n`,
equipped with the corresponding quotient of the structure sheaf.

This is the analytic analogue of an affine scheme. -/
def IsLocalModel (X : LocallyRingedSpace.{u}) : Prop :=
  ∃ (n k : ℕ) (U : Opens (complexAffineSpace.{u} n))
    (i : X ⟶ (complexAffineSpace.{u} n).restrict U.isOpenEmbedding)
    (f : Fin k → ((complexAffineSpace.{u} n).restrict U.isOpenEmbedding).presheaf.obj (op ⊤)),
    IsCutOutBy i f

/-- The underlying homeomorphism of an isomorphism of locally ringed spaces. -/
noncomputable def _root_.AlgebraicGeometry.LocallyRingedSpace.homeoOfIso (e : X ≅ Y) : X ≃ₜ Y :=
  TopCat.homeoOfIso (LocallyRingedSpace.forgetToTop.mapIso e)

@[simp]
lemma _root_.AlgebraicGeometry.LocallyRingedSpace.homeoOfIso_apply (e : X ≅ Y) (x : X) :
    LocallyRingedSpace.homeoOfIso e x = e.hom.base x :=
  rfl

/-- Cutting out by a family of sections is invariant under precomposition with an isomorphism:
if `i : X ⟶ Y` cuts out `X` by `f` and `e : X' ≅ X`, then `e.hom ≫ i` cuts out `X'` by `f`. -/
theorem IsCutOutBy.comp_iso {X' : LocallyRingedSpace.{u}} {i : X ⟶ Y} {k : ℕ}
    {f : Fin k → Y.presheaf.obj (op ⊤)} (hf : IsCutOutBy i f) (e : X' ≅ X) :
    IsCutOutBy (e.hom ≫ i) f := by
  have hstalk (x : X') : Function.Bijective (e.hom.stalkMap x).hom :=
    ConcreteCategory.bijective_of_isIso _
  have hcomp (x : X') (a : Y.presheaf.stalk ((e.hom ≫ i).base x)) :
      ((e.hom ≫ i).stalkMap x).hom a =
        (e.hom.stalkMap x).hom ((i.stalkMap (e.hom.base x)).hom a) := by
    rw [LocallyRingedSpace.stalkMap_comp]
    rfl
  have hsurj : Function.Surjective ⇑e.hom.base :=
    (LocallyRingedSpace.homeoOfIso e).surjective
  refine ⟨hf.isClosedEmbedding.comp (LocallyRingedSpace.homeoOfIso e).isClosedEmbedding, ?_,
    fun x ↦ ?_, fun x ↦ ?_⟩
  · rw [show ⇑(e.hom ≫ i).base = ⇑i.base ∘ ⇑e.hom.base from rfl, Set.range_comp,
      hsurj.range_eq, Set.image_univ]
    exact hf.range_base
  · rw [show ⇑((e.hom ≫ i).stalkMap x).hom =
      ⇑(e.hom.stalkMap x).hom ∘ ⇑(i.stalkMap (e.hom.base x)).hom from funext (hcomp x)]
    exact (hstalk x).surjective.comp (hf.surjective_stalkMap _)
  · have hker : RingHom.ker ((e.hom ≫ i).stalkMap x).hom =
        RingHom.ker (i.stalkMap (e.hom.base x)).hom := by
      ext a
      simp only [RingHom.mem_ker, hcomp x a]
      exact ⟨fun h ↦ (hstalk x).injective (h.trans (map_zero _).symm),
        fun h ↦ by rw [h, map_zero]⟩
    rw [hker]
    exact hf.ker_stalkMap _

/-- The sections cutting out `X` inside `Y` pull back to zero on `X`. -/
lemma IsCutOutBy.c_app_eq_zero {i : X ⟶ Y} {k : ℕ} {f : Fin k → Y.presheaf.obj (op ⊤)}
    (hcut : IsCutOutBy i f) (j : Fin k) :
    i.c.app (op ⊤) (f j) = 0 := by
  refine TopCat.Presheaf.section_ext X.sheaf _ _ _ fun x _ ↦ ?_
  have hker : Y.presheaf.Γgerm (i.base x) (f j) ∈ RingHom.ker (i.stalkMap x).hom := by
    rw [hcut.ker_stalkMap x]
    exact Submodule.subset_span ⟨j, rfl⟩
  have h0 : (i.stalkMap x) (Y.presheaf.Γgerm (i.base x) (f j)) = 0 := hker
  exact ((LocallyRingedSpace.stalkMap_germ_apply i ⊤ x trivial (f j)).symm.trans h0).trans
    (map_zero _).symm


/-- Being a local model is invariant under isomorphism of locally ringed spaces. -/
theorem IsLocalModel.of_iso {M N : LocallyRingedSpace.{u}} (e : N ≅ M) (hM : IsLocalModel M) :
    IsLocalModel N := by
  obtain ⟨n, k, U, i, f, hcut⟩ := hM
  exact ⟨n, k, U, e.hom ≫ i, f, hcut.comp_iso e⟩

section CAlgebraStructure

/-- The `ℂ`-algebra structure on the structure sheaf of a locally ringed space is recorded as
a ring homomorphism `α : ℂ →+* Γ(X, 𝒪_X)` into the global sections; the ring of sections over
every open subset then becomes a `ℂ`-algebra via restriction. In particular `α` induces a
`ℂ`-algebra structure on every open subspace of `X`, which this definition provides. -/
noncomputable def _root_.AlgebraicGeometry.LocallyRingedSpace.resAlgMap
    (X : LocallyRingedSpace.{u}) (α : ℂ →+* X.presheaf.obj (op ⊤)) (U : Opens X) :
    ℂ →+* (X.restrict U.isOpenEmbedding).presheaf.obj (op ⊤) :=
  (X.presheaf.map (homOfLE le_top).op).hom.comp α

/-- The canonical `ℂ`-algebra structure on an open subspace of `ℂ^n`: the constant
holomorphic functions. This is the reference structure which the charts of an analytic space
are required to respect. -/
noncomputable def constantsAlgMap (n : ℕ) (V : Opens (complexAffineSpace.{u} n)) :
    ℂ →+* ((complexAffineSpace.{u} n).restrict V.isOpenEmbedding).presheaf.obj (op ⊤) :=
  Algebra.algebraMap ℂ (OkaRing (V.isOpenEmbedding.isOpenMap.functor.obj ⊤))

/-- A morphism `i : X ⟶ Y` of locally ringed spaces whose structure sheaves carry `ℂ`-algebra
structures `α` and `β` is **`ℂ`-linear** if pulling back global sections intertwines `β` and
`α`. Since the `ℂ`-algebra structure on the sections over any open subset is the restriction
of the global one, this makes every component of `i.c` a `ℂ`-algebra homomorphism.

Without this condition a morphism of locally ringed spaces between complex analytic spaces
may be antiholomorphic: complex conjugation is a ring automorphism of the sheaf of
holomorphic functions, but it is not `ℂ`-linear. -/
def IsCLinearHom {X Y : LocallyRingedSpace.{u}} (i : X ⟶ Y)
    (α : ℂ →+* X.presheaf.obj (op ⊤)) (β : ℂ →+* Y.presheaf.obj (op ⊤)) : Prop :=
  ∀ c : ℂ, LocallyRingedSpace.Γ.map i.op (β c) = α c

lemma IsCLinearHom.id {X : LocallyRingedSpace.{u}} (α : ℂ →+* X.presheaf.obj (op ⊤)) :
    IsCLinearHom (𝟙 X) α α := fun c ↦ by
  rw [op_id, CategoryTheory.Functor.map_id]
  rfl

lemma IsCLinearHom.comp {X Y Z : LocallyRingedSpace.{u}} {f : X ⟶ Y} {g : Y ⟶ Z}
    {α : ℂ →+* X.presheaf.obj (op ⊤)} {β : ℂ →+* Y.presheaf.obj (op ⊤)}
    {γ : ℂ →+* Z.presheaf.obj (op ⊤)}
    (hf : IsCLinearHom f α β) (hg : IsCLinearHom g β γ) :
    IsCLinearHom (f ≫ g) α γ := fun c ↦ by
  rw [op_comp, Functor.map_comp, ConcreteCategory.comp_apply, hg c, hf c]

end CAlgebraStructure

/-- A **complex analytic space** is a locally ringed space `X`, together with a `ℂ`-algebra
structure on its structure sheaf, such that every point of `X` has an open neighbourhood
which is — compatibly with the `ℂ`-algebra structures — cut out by finitely many holomorphic
functions inside an open subset of some `ℂ^n`, i.e. a neighbourhood which is a local model as
a `ℂ`-ringed space.

Since being cut out transfers along isomorphisms (`IsCutOutBy.comp_iso`), requiring the
restriction of `X` itself to be cut out is equivalent to requiring an isomorphism onto a
local model; stating it directly for the restriction avoids transporting the `ℂ`-algebra
structure through the isomorphism.

The `ℂ`-linearity of the charts cannot be dropped: an isomorphism of locally ringed spaces
onto a local model may be conjugate-linear, so without it the definition would also admit
spaces glued along antiholomorphic maps (dianalytic spaces such as Klein surfaces), which are
not complex analytic spaces.

Compare `AlgebraicGeometry.Scheme`, where the local models are the spectra of commutative
rings. As there, no separation axiom is imposed; the Hausdorffness assumed by most classical
treatments should be added as a mixin where needed. -/
structure AnalyticSpace extends LocallyRingedSpace.{u} where
  /-- The `ℂ`-algebra structure on the structure sheaf, as a ring homomorphism into the
  global sections. -/
  algebraMap : ℂ →+* toLocallyRingedSpace.presheaf.obj (op ⊤)
  /-- Every point has a neighbourhood which, compatibly with the `ℂ`-algebra structures, is
  cut out by finitely many holomorphic functions inside an open subset of some `ℂ^n`. -/
  local_model : ∀ x : toLocallyRingedSpace, ∃ (U : OpenNhds x) (n k : ℕ)
    (V : Opens (complexAffineSpace.{u} n))
    (i : toLocallyRingedSpace.restrict U.1.isOpenEmbedding ⟶
      (complexAffineSpace.{u} n).restrict V.isOpenEmbedding)
    (f : Fin k → ((complexAffineSpace.{u} n).restrict V.isOpenEmbedding).presheaf.obj (op ⊤)),
    IsCutOutBy i f ∧
      IsCLinearHom i (toLocallyRingedSpace.resAlgMap algebraMap U.1) (constantsAlgMap n V)

namespace AnalyticSpace

instance : CoeSort AnalyticSpace (Type u) where
  coe X := X.carrier

/-- The type of open sets of a complex analytic space. -/
abbrev Opens (X : AnalyticSpace.{u}) : Type u := TopologicalSpace.Opens X

/-- A morphism of complex analytic spaces is a morphism of the underlying locally ringed
spaces which is `ℂ`-linear, i.e. compatible with the `ℂ`-algebra structures on the structure
sheaves. Plain morphisms of locally ringed spaces would also include antiholomorphic maps
such as complex conjugation. -/
@[ext]
structure Hom (X Y : AnalyticSpace.{u}) extends
  toLRSHom' : X.toLocallyRingedSpace.Hom Y.toLocallyRingedSpace where
  /-- Pulling back sections is `ℂ`-linear. -/
  isCLinear : IsCLinearHom toLRSHom' X.algebraMap Y.algebraMap

/-- Cast a morphism of analytic spaces to a morphism of locally ringed spaces. -/
abbrev Hom.toLRSHom {X Y : AnalyticSpace.{u}} (f : X.Hom Y) :
    X.toLocallyRingedSpace ⟶ Y.toLocallyRingedSpace :=
  f.toLRSHom'

/-- Complex analytic spaces form a (non-full) subcategory of locally ringed spaces. -/
instance : Category AnalyticSpace.{u} where
  Hom := Hom
  id X := ⟨𝟙 X.toLocallyRingedSpace, IsCLinearHom.id X.algebraMap⟩
  comp f g := ⟨f.toLRSHom ≫ g.toLRSHom, f.isCLinear.comp g.isCLinear⟩

/-- The forgetful functor from complex analytic spaces to locally ringed spaces. -/
def forgetToLocallyRingedSpace : AnalyticSpace.{u} ⥤ LocallyRingedSpace.{u} where
  obj X := X.toLocallyRingedSpace
  map f := f.toLRSHom

instance : forgetToLocallyRingedSpace.Faithful where
  map_injective {_ _ f g} h := by
    cases f
    cases g
    cases h
    rfl

end AnalyticSpace

section ComplexAffineSpace

variable (n : ℕ)

/-- The identity of the top open subspace of `ℂ^n` cuts it out inside itself by the empty
family of holomorphic functions. -/
theorem isCutOutBy_id_restrict_top :
    IsCutOutBy (𝟙 ((complexAffineSpace.{u} n).restrict
      (⊤ : Opens (complexAffineSpace.{u} n)).isOpenEmbedding)) Fin.elim0 := by
  refine ⟨?_, ?_, ?_, ?_⟩
  · simpa using IsClosedEmbedding.id
  · simp
  · intro x
    simp only [LocallyRingedSpace.stalkMap_id]
    exact fun y ↦ ⟨y, rfl⟩
  · intro x
    simp only [LocallyRingedSpace.stalkMap_id, Set.range_eq_empty, Ideal.span_empty]
    ext a
    exact Iff.rfl

/-- Complex affine `n`-space, restricted to its top open subset, is a local model: it is cut
out inside itself by the empty family of holomorphic functions. -/
theorem isLocalModel_complexAffineSpace_restrict_top :
    IsLocalModel ((complexAffineSpace.{u} n).restrict
      (⊤ : Opens (complexAffineSpace.{u} n)).isOpenEmbedding) :=
  ⟨n, 0, ⊤, 𝟙 _, Fin.elim0, isCutOutBy_id_restrict_top n⟩

/-- The identity chart of `ℂ^n` is `ℂ`-linear: the constant functions restrict to the
constant functions. -/
theorem isCLinearHom_id_restrict_top :
    IsCLinearHom (𝟙 ((complexAffineSpace.{u} n).restrict
        (⊤ : Opens (complexAffineSpace.{u} n)).isOpenEmbedding))
      ((_root_.complexAffineSpace.{u} n).resAlgMap (Algebra.algebraMap ℂ (OkaRing ⊤)) ⊤)
      (constantsAlgMap n ⊤) := fun c ↦ by
  rw [op_id, CategoryTheory.Functor.map_id]
  rfl

/-- Complex affine `n`-space `ℂ^n` as a complex analytic space, with the constant functions
as `ℂ`-algebra structure. -/
noncomputable def AnalyticSpace.complexAffineSpace (n : ℕ) : AnalyticSpace.{u} where
  toLocallyRingedSpace := _root_.complexAffineSpace.{u} n
  algebraMap := Algebra.algebraMap ℂ (OkaRing ⊤)
  local_model _ :=
    ⟨⟨⊤, trivial⟩, n, 0, ⊤, 𝟙 _, Fin.elim0, isCutOutBy_id_restrict_top n,
      isCLinearHom_id_restrict_top n⟩

end ComplexAffineSpace

end ComplexAnalytic
